# Supabase — copy this file to `.env` and fill in your project's values.
# Find them in the Supabase dashboard: Project Settings → API.
# These are EXPO_PUBLIC_* so they are bundled into the client; the anon key is
# safe to expose because every table is protected by Row-Level Security.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
